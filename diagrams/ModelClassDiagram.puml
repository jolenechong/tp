@startuml
!include style.puml
skinparam arrowThickness 1.1
skinparam arrowColor MODEL_COLOR
skinparam classBackgroundColor MODEL_COLOR

Package Model as ModelPackage <<Rectangle>>{
Class "<<interface>>\nReadOnlyVendorVault" as ReadOnlyVendorVault
Class "<<interface>>\nReadOnlyUserPrefs" as ReadOnlyUserPrefs
Class "<<interface>>\nModel" as Model
Class VendorVault
Class ModelManager
Class UserPrefs

Class UniquePersonList
Class Person
Class Address
Class Email
Class Name
Class ProductName
Class Phone
Class Tag

Class UniqueProductList
Class Product
Class Identifier
Class ProductName
Class RestockThreshold

Class Aliases
Class "<<interface>>\nReadOnlyAliases" as ReadOnlyAliases

Class I #FFFFFF
}

Class HiddenOutside #FFFFFF
HiddenOutside ..> Model

VendorVault .up.|> ReadOnlyVendorVault

ModelManager .up.|> Model
Model ..> ReadOnlyUserPrefs
Model ..> ReadOnlyVendorVault
Model ..> ReadOnlyAliases
ModelManager --> "1" VendorVault
ModelManager -right-> "1" UserPrefs
UserPrefs .up.|> ReadOnlyUserPrefs
ModelManager --> "1" Aliases
Aliases .up.|> ReadOnlyAliases

VendorVault *--> "1" UniquePersonList
UniquePersonList --> "~* all" Person
Person *--> Name
Person *--> Phone
Person *--> Email
Person *--> Address
Person *--> "*" Tag

VendorVault *--> "1" UniqueProductList
UniqueProductList --> "~* all" Product
Product *--> Identifier
Product *--> ProductName
Product *--> Email
Product *--> RestockThreshold

Person -[hidden]up--> I
UniquePersonList -[hidden]right-> I

Name -[hidden]right-> Phone
Phone -[hidden]right-> Address
Address -[hidden]right-> Email
Email -[hidden]left-> RestockThreshold
Email -[hidden]left-> Identifier
UniqueProductList -[hidden]right-> UniquePersonList

ModelManager --> "~* filtered" Person
ModelManager --> "~* filtered" Product
@enduml
