@startuml
!include ../style.puml
skinparam ArrowFontStyle plain

box "Logic" LOGIC_COLOR_T1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant ":AddressBookParser" as AddressBookParser LOGIC_COLOR
participant "l:ListCommand" as ListCommand LOGIC_COLOR
end box

box "Model" MODEL_COLOR_T1
participant ":Model" as ModelManager MODEL_COLOR
end box

[-> LogicManager : execute("ls")
activate LogicManager

LogicManager -> AddressBookParser : parseCommand("ls")
activate AddressBookParser

note right of AddressBookParser
    Extracts command word "ls"
    from user input
end note

AddressBookParser -> ModelManager : findAlias("ls")
activate ModelManager

ModelManager --> AddressBookParser : alias
deactivate ModelManager

note right of AddressBookParser
    alias.getOriginalCommand()
    returns "list"
end note

create ListCommand

AddressBookParser -> ListCommand : ListCommand()
activate ListCommand
ListCommand --> AddressBookParser
deactivate ListCommand

AddressBookParser --> LogicManager : l
deactivate AddressBookParser

LogicManager -> ListCommand : execute()
activate ListCommand

ListCommand --> LogicManager : result
deactivate ListCommand
ListCommand -[hidden]-> LogicManager : result
destroy ListCommand

[<-- LogicManager : result
deactivate LogicManager

@enduml
