@startuml
!include ../style.puml
skinparam ArrowFontStyle plain

box "Logic" LOGIC_COLOR_T1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant ":AddressBookParser" as AddressBookParser LOGIC_COLOR
participant ":ListCommand" as ListCommand LOGIC_COLOR
end box

box "Model" MODEL_COLOR_T1
participant ":Model" as Model MODEL_COLOR
end box


[-> LogicManager : execute("ls")
activate LogicManager

LogicManager -> AddressBookParser : parseCommand("ls")
activate AddressBookParser

note right of AddressBookParser
    Extracts command word "ls"
    from user input
end note

AddressBookParser -> Model : findAlias("ls")
activate Model
Model --> AddressBookParser : alias
deactivate Model

note right of AddressBookParser
    alias.getOriginalCommand()
    returns "list"
end note

create ListCommand
AddressBookParser -> ListCommand : new ListCommand()
AddressBookParser --> LogicManager : listCommand
deactivate AddressBookParser

LogicManager -> ListCommand : execute(model)
activate ListCommand
ListCommand --> LogicManager : commandResult
deactivate ListCommand

[<-- LogicManager : commandResult
deactivate LogicManager

@enduml